{
    "config": {
        "platform": {
            "php": "7.1"
        },
        "sort-packages": true,
        "vendor-dir": "./app/vendor/"
    },
    "autoload": {
        "psr-4": {
            "App\\": "./app/src/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "./platform/",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "./framework/",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "jamesblanksby/x-framework": "@dev",
        "jamesblanksby/x-platform": "@dev"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^2.19",
        "phpstan/phpstan": "^1.4"
    },
    "scripts": {
        "csfixer": "composer docker -- app/vendor/bin/php-cs-fixer --config=.php-cs-fixer.php fix",
        "docker": "docker exec -it -w /var/www/html/$(basename $(pwd)) developer.php-7",
        "phpstan": "composer docker -- app/vendor/bin/phpstan --configuration=.phpstan.php --memory-limit=1G analyse",
        "lint": [
            "@csfixer",
            "@phpstan"
        ]
    }
}
